@page "/videoEditor"

@using System.Net.Http.Json
@using System.Text.Json
@using VideoAnonymizer.Web.Modules.Components
@using VideoAnonymizer.Web.Shared.DTO
@inject HttpClient Http

<PageTitle>Video Editor Test</PageTitle>

@if (_isLoading)
{
    <p>Loading sample data...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <p style="color:red">@_error</p>
}
else
{
    <VideoEditor VideoId="@_videoId"
                 VideoSourceUrl="@_videoUrl"
                 Frames="@_frames" />
}

@code {
    private readonly JsonSerializerOptions _jsonOptions = new(JsonSerializerDefaults.Web);

    private bool _isLoading = true;
    private string? _error;
    private Guid _videoId;
    private string _videoUrl = "/test-data/sample.frame-analysis.mp4";
    private IReadOnlyList<AnalyzedFrameDto> _frames = Array.Empty<AnalyzedFrameDto>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<SampleFrameResponse>(
                "/test-data/sample.json",
                _jsonOptions);

            _frames = response?.Payload ?? new List<AnalyzedFrameDto>();

            _videoId = _frames.FirstOrDefault()?.VideoId ?? Guid.Empty;

            if (_videoId == Guid.Empty)
            {
                _error = "No sample frames found in sample.json.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load sample data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    public sealed class SampleFrameResponse
    {
        public List<AnalyzedFrameDto> Payload { get; set; } = [];
    }
}