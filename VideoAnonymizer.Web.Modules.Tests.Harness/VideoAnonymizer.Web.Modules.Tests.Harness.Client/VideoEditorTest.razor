@page "/videoEditor"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using System.Net.Http.Json
@using System.Text.Json
@using VideoAnonymizer.Web.Modules.Components
@using VideoAnonymizer.Web.Shared.DTO
@inject HttpClient Http

<PageTitle>Video Editor Test</PageTitle>
<MudThemeProvider @ref="_themeProvider"
                  IsDarkMode="@true" />
<MudDialogProvider />
<MudSnackbarProvider />


@if (_isLoading)
{
    <p>Loading sample data...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <p style="color:red">@_error</p>
}
else
{
    <ErrorBoundary>
        <ChildContent>
            <MudContainer MaxWidth="MaxWidth.Large"> 
                <MudPaper Class="pa-6">
                    <VideoEditor VideoId="@_videoId"
                                 VideoSourceUrl="@_videoUrl"
                                 Frames="@_frames" />
                </MudPaper>
            </MudContainer>
        </ChildContent>
        <ErrorContent Context="ex">
            <pre style="white-space: pre-wrap; color: red;">@ex.ToString()</pre>
        </ErrorContent>
    </ErrorBoundary>
}

@code {
    private readonly JsonSerializerOptions _jsonOptions = new(JsonSerializerDefaults.Web);

    private bool _isLoading = true;
    private string? _error;
    private Guid _videoId;
    private string _videoUrl = "/test-data/sample.frame-analysis.mp4";
    private IReadOnlyList<AnalyzedFrameDto> _frames = Array.Empty<AnalyzedFrameDto>();
    private MudThemeProvider? _themeProvider;
    private bool _isDarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _themeProvider is null)
            return;

        _isDarkMode = await _themeProvider.GetSystemDarkModeAsync();
        StateHasChanged();

        await _themeProvider.WatchSystemDarkModeAsync(async isDark =>
        {
            _isDarkMode = isDark;
            await InvokeAsync(StateHasChanged);
        });
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<SampleFrameResponse>(
                "/test-data/sample.json",
                _jsonOptions);

            _frames = response?.Payload ?? new List<AnalyzedFrameDto>();

            _videoId = _frames.FirstOrDefault()?.VideoId ?? Guid.Empty;

            if (_videoId == Guid.Empty)
            {
                _error = "No sample frames found in sample.json.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load sample data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    public sealed class SampleFrameResponse
    {
        public List<AnalyzedFrameDto> Payload { get; set; } = [];
    }
}