@implements IAsyncDisposable

@using VideoAnonymizer.Web.Shared.DTO

@inject IJSRuntime JS

<div class="video-overlay-container">
    <video @ref="_videoRef"
           class="video-element"
           src="@VideoUrl"
           controls
           @ontimeupdate="OnTimeUpdate">
    </video>

    @if (CurrentFrame is not null)
    {
        <div class="overlay-layer">
            @foreach (var obj in CurrentFrame.DetectedObjects)
            {
                var key = GetObjectKey(obj);

                if (!ActiveObjectKeys.Contains(key))
                    continue;

                <div class="bounding-box"
                     style="@GetBoxStyle(obj, key)">
                </div>
            }
        </div>
    }
</div>

@code {
    private ElementReference _videoRef;
    private IJSObjectReference? _module;

    [Parameter, EditorRequired] public string VideoUrl { get; set; } = string.Empty;
    [Parameter] public double CurrentTimeSeconds { get; set; }
    [Parameter] public AnalyzedFrameDto? CurrentFrame { get; set; }
    [Parameter] public Dictionary<string, string> ObjectColors { get; set; } = [];
    [Parameter] public HashSet<string> ActiveObjectKeys { get; set; } = [];
    [Parameter] public EventCallback<double> OnTimeChanged { get; set; }

    private double _videoWidth;
    private double _videoHeight;
    private double _clientWidth;
    private double _clientHeight;

    private double ScaleX => _videoWidth <= 0 ? 1 : _clientWidth / _videoWidth;
    private double ScaleY => _videoHeight <= 0 ? 1 : _clientHeight / _videoHeight;

    private double _lastAppliedTime = -1;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./Components/VideoOverlay.razor.js");
        }

        if (_module is null)
            return;

        if (Math.Abs(CurrentTimeSeconds - _lastAppliedTime) > 0.05)
        {
            await _module.InvokeVoidAsync("setCurrentTime", _videoRef, CurrentTimeSeconds);
            _lastAppliedTime = CurrentTimeSeconds;
        }

        await UpdateVideoSizeAsync();
    }

    private async Task UpdateVideoSizeAsync()
    {
        if (_module is null)
            return;

        var size = await _module.InvokeAsync<VideoSizeDto>("getVideoSize", _videoRef);

        _videoWidth = size.VideoWidth;
        _videoHeight = size.VideoHeight;
        _clientWidth = size.ClientWidth;
        _clientHeight = size.ClientHeight;
    }

    private async Task OnTimeUpdate()
    {
        if (_module is null)
            return;

        var time = await _module.InvokeAsync<double>("getCurrentTime", _videoRef);
        _lastAppliedTime = time;

        await UpdateVideoSizeAsync();
        await OnTimeChanged.InvokeAsync(time);
    }

    private string GetObjectKey(DetectedObjectDto obj)
        => obj.TrackId.HasValue
            ? $"track:{obj.TrackId.Value}"
            : $"object:{obj.Id}";

    private string GetBoxStyle(DetectedObjectDto obj, string key)
    {
        var color = ObjectColors.TryGetValue(key, out var value) ? value : "#ff0000";

        var left = obj.X * ScaleX;
        var top = obj.Y * ScaleY;
        var width = obj.Width * ScaleX;
        var height = obj.Height * ScaleY;

        return $"""
        left:{left}px;
        top:{top}px;
        width:{width}px;
        height:{height}px;
        border:2px solid {color};
    """;
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
            await _module.DisposeAsync();
    }

    private sealed class VideoSizeDto
    {
        public double VideoWidth { get; set; }
        public double VideoHeight { get; set; }
        public double ClientWidth { get; set; }
        public double ClientHeight { get; set; }
    }
}