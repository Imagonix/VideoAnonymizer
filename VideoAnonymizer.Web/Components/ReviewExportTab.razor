@using VideoAnonymizer.Web.Modules.Components
@using VideoAnonymizer.Web.Modules.Actions
@using VideoAnonymizer.Web.Shared.DTO
@using VideoAnonymizer.Web.Shared
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar

<MudPaper Class="pa-6">
    <MudStack Spacing="2">
        <MudPaper Class="pa-3 mb-3">
            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                    <MudStack Spacing="1" Style="width: 220px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.subtitle2">Blur size</MudText>
                            <MudTooltip Text="Controls how large the anonymized area is compared to the detected face box. Example: 120% means the blur area is 20% larger than the detected box.">
                                <MudIcon Icon="@Icons.Material.Filled.Info"
                                         Size="Size.Small"
                                         Color="Color.Info" />
                            </MudTooltip>
                        </MudStack>

                        <MudNumericField T="int"
                                         Value="BlurSizePercent"
                                         ValueChanged="OnBlurSizeChanged"
                                         Min="100"
                                         Max="300"
                                         Step="10"
                                         Adornment="Adornment.End"
                                         AdornmentText="%"
                                         Immediate="false" />
                    </MudStack>

                    <MudStack Spacing="1" Style="width: 220px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.subtitle2">Time buffer</MudText>
                            <MudTooltip Text="Adds blur time before and after a detection, reducing flicker when detections appear or disappear. Example: 300 ms blurs 0.3 seconds before and after detection.">
                                <MudIcon Icon="@Icons.Material.Filled.Info"
                                         Size="Size.Small"
                                         Color="Color.Info" />
                            </MudTooltip>
                        </MudStack>

                        <MudNumericField T="int"
                                         Value="TimeBufferMs"
                                         ValueChanged="OnTimeBufferChanged"
                                         Min="0"
                                         Max="1000"
                                         Step="50"
                                         Adornment="Adornment.End"
                                         AdornmentText="ms"
                                         Immediate="false" />
                    </MudStack>
                </MudStack>

                <div style="position: relative; display: inline-flex; align-items: center;"
                     @onmouseenter="() => _showActionHistory = true"
                     @onmouseleave="() => _showActionHistory = false">

                    @if (_videoEditorProcessing)
                    {
                        <MudProgressCircular Indeterminate="true"
                                             Size="Size.Small"
                                             Color="Color.Secondary"
                                             Style="align-self: start; margin-top: 4px;" />
                    }
                    else if (_hasErrors)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Save"
                                 Size="Size.Small"
                                 Color="Color.Error"
                                 Style="align-self: start; margin-top: 4px;" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Save"
                                 Size="Size.Small"
                                 Color="Color.Primary"
                                 Style="align-self: start; margin-top: 4px;" />
                    }

                    @if (_showActionHistory)
                    {
                        <MudPaper Class="pa-2"
                                  Style="position: absolute; top: 100%; right: 0; z-index: 1000; min-width: 300px; max-height: 400px; overflow-y: auto; margin-top: 4px;">
                            <MudText Typo="Typo.caption" Class="mb-2 mud-text-secondary">
                                @(_videoEditorProcessing ? "Saving..." : "Saved")
                            </MudText>
                            @if (_actionHistory.Count == 0)
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">No recent actions</MudText>
                            }
                            else
                            {
                                @foreach (var item in _actionHistory.AsEnumerable().Reverse())
                                {
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="my-1">
                                        @if (item.Status == ActionStatus.Success)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                        }
                                        else if (item.Status == ActionStatus.Failed)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" />
                                        }
                                        else
                                        {
                                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Secondary" />
                                        }
                                        <MudText Typo="Typo.caption">@item.Description</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="margin-left: auto;">
                                            @item.Timestamp.ToLocalTime().ToString("HH:mm:ss")
                                        </MudText>
                                    </MudStack>
                                }
                            }
                        </MudPaper>
                    }
                </div>
            </MudStack>

            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                These settings apply to the whole video, not to individual objects.
                The preview shows the affected area, not the final blur rendering.
            </MudAlert>
        </MudPaper>
        @if (ShowEditor && VideoId.HasValue && !string.IsNullOrWhiteSpace(VideoSourceUrl))
        {
            <VideoEditor @ref="_videoEditor"
                         VideoId="@VideoId.Value"
                         VideoSourceUrl="@VideoSourceUrl"
                         Frames="@Frames"
                         BlurSizePercent="@BlurSizePercent"
                         TimeBufferMs="@TimeBufferMs"
                         IsProcessingChanged="OnVideoEditorProcessingChanged"
                         OnAction="OnVideoEditorAction" />
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Secondary"
                   Disabled="!ShowEditor"
                   OnClick="OnStartAnonymizationClicked">
            Anonymize selected objects
        </MudButton>

    </MudStack>
</MudPaper>

@code {
    private class ActionHistoryItem(string description, DateTime timestamp)
    {
        public string Description { get; } = description;
        public ActionStatus Status { get; set; } = ActionStatus.Pending;
        public DateTime Timestamp { get; } = timestamp;
    }

    private enum ActionStatus { Pending, Success, Failed }

    private VideoEditor? _videoEditor;
    private List<AnalyzedFrameDto> _capturedFrames = [];
    private bool _videoEditorProcessing;
    private readonly List<ActionHistoryItem> _actionHistory = [];
    private bool _showActionHistory;
    private bool _hasErrors;

    private readonly List<VideoEditorAction> _undoHistory = [];
    private int _historyIndex = -1;

    [Parameter]
    public Guid? VideoId { get; set; }

    [Parameter]
    public string? VideoSourceUrl { get; set; }

    [Parameter]
    public List<AnalyzedFrameDto> Frames { get; set; } = [];

    [Parameter]
    public bool ShowEditor { get; set; }

    [Parameter, EditorRequired]
    public EventCallback StartAnonymization { get; set; }

    [Parameter]
    public int BlurSizePercent { get; set; } = 120;

    [Parameter]
    public int TimeBufferMs { get; set; } = 300;

    public IReadOnlyList<AnalyzedFrameDto> CapturedFrames => _capturedFrames;

    private void OnVideoEditorProcessingChanged(bool isIdle)
    {
        _videoEditorProcessing = !isIdle;
        StateHasChanged();
    }

    private static string GetActionDescription(VideoEditorAction action) => action switch
    {
        ObjectAddedAction => "Added new bounding box",
        ObjectUpdatedAction a => a.OperationType switch
        {
            "toggle" => "Toggled object selection",
            "reassign" => "Reassigned track ID",
            "move" => "Moved bounding box",
            "resize" => "Resized bounding box",
            _ => "Updated bounding box"
        },
        ObjectsBulkUpdatedAction a => a.OperationType switch
        {
            "merge" => $"Merged {a.Objects.Count} objects",
            "split" => $"Split {a.Objects.Count} objects",
            "toggle" => $"Toggled {a.Objects.Count} objects",
            "reassign" => $"Reassigned track ({a.Objects.Count} objects)",
            _ => $"Updated {a.Objects.Count} objects"
        },
        UndoAction => "Undo",
        RedoAction => "Redo",
        _ => "Unknown action"
    };

    private ActionHistoryItem AddAction(string description)
    {
        var item = new ActionHistoryItem(description, DateTime.UtcNow);
        _actionHistory.Add(item);
        if (_actionHistory.Count > 20)
            _actionHistory.RemoveAt(0);
        return item;
    }

    private void MarkActionFailed(ActionHistoryItem item)
    {
        item.Status = ActionStatus.Failed;
        _hasErrors = true;
        InvokeAsync(StateHasChanged);
        Snackbar.Add("Failed to save changes. Please refresh the page.", Severity.Error);
    }

    private async Task OnVideoEditorAction(VideoEditorAction action)
    {
        using var client = HttpClientFactory.CreateClient("ApiService");
        var item = AddAction(GetActionDescription(action));

        try
        {
            switch (action)
            {
                case ObjectAddedAction a:
                    await client.PostAsJsonAsync(
                        $"/{SharedConstants.Paths.Video}/{a.VideoId}/{SharedConstants.Paths.AnalyzedFrame}/{a.AnalyzedFrameId}/{SharedConstants.Paths.DetectedObject}/", a.Object);
                    AddToUndoHistory(a);
                    break;

                case ObjectUpdatedAction a:
                    await client.PutAsJsonAsync(
                        $"/{SharedConstants.Paths.Video}/{a.VideoId}/{SharedConstants.Paths.AnalyzedFrame}/{a.AnalyzedFrameId}/{SharedConstants.Paths.DetectedObject}/{a.Object.Id}", a.Object);
                    AddToUndoHistory(a);
                    break;

                case ObjectsBulkUpdatedAction a:
                    await client.PatchAsJsonAsync(
                        $"/{SharedConstants.Paths.Video}/{a.VideoId}/{SharedConstants.Paths.DetectedObjects}", a.Objects);
                    AddToUndoHistory(a);
                    break;

                case UndoAction _:
                    await ApplyUndoRedo(client, isRedo: false);
                    break;

                case RedoAction _:
                    await ApplyUndoRedo(client, isRedo: true);
                    break;
            }

            item.Status = ActionStatus.Success;
        }
        catch
        {
            MarkActionFailed(item);
        }
    }

    private void AddToUndoHistory(VideoEditorAction action)
    {
        if (_historyIndex < _undoHistory.Count - 1)
        {
            _undoHistory.RemoveRange(_historyIndex + 1, _undoHistory.Count - _historyIndex - 1);
        }
        _undoHistory.Add(action);
        _historyIndex = _undoHistory.Count - 1;
    }

    private async Task ApplyUndoRedo(HttpClient client, bool isRedo)
    {
        if (isRedo)
        {
            if (_historyIndex >= _undoHistory.Count - 1) return;
            _historyIndex++;
        }
        else
        {
            if (_historyIndex < 0) return;
        }

        var action = _undoHistory[_historyIndex];

        switch (action)
        {
            case ObjectAddedAction a:
                if (isRedo)
                {
                    await client.PostAsJsonAsync(
                        $"/{SharedConstants.Paths.Video}/{a.VideoId}/{SharedConstants.Paths.AnalyzedFrame}/{a.AnalyzedFrameId}/{SharedConstants.Paths.DetectedObject}/", a.Object);
                    if (_videoEditor is not null)
                        await _videoEditor.PushChangesToVue(new DetectedObjectChangeSet
                        {
                            ObjectsToUpdate = [], ObjectsToRemove = [], ObjectsToAdd = [a.Object]
                        });
                }
                else
                {
                    await client.DeleteAsync(
                        $"/{SharedConstants.Paths.Video}/{a.VideoId}/{SharedConstants.Paths.AnalyzedFrame}/{a.AnalyzedFrameId}/{SharedConstants.Paths.DetectedObject}/{a.Object.Id}");
                    if (_videoEditor is not null)
                        await _videoEditor.PushChangesToVue(new DetectedObjectChangeSet
                        {
                            ObjectsToUpdate = [], ObjectsToRemove = [a.Object.Id.ToString()], ObjectsToAdd = []
                        });
                }
                break;

            case ObjectUpdatedAction a:
                var updateState = isRedo ? a.AfterState : a.BeforeState;
                if (updateState.Count > 0)
                {
                    await client.PutAsJsonAsync(
                        $"/{SharedConstants.Paths.Video}/{a.VideoId}/{SharedConstants.Paths.AnalyzedFrame}/{a.AnalyzedFrameId}/{SharedConstants.Paths.DetectedObject}/{updateState[0].Id}", updateState[0]);
                    if (_videoEditor is not null)
                        await _videoEditor.PushChangesToVue(new DetectedObjectChangeSet
                        {
                            ObjectsToUpdate = updateState, ObjectsToRemove = [], ObjectsToAdd = []
                        });
                }
                break;

            case ObjectsBulkUpdatedAction a:
                var bulkState = isRedo ? a.AfterState : a.BeforeState;
                if (bulkState.Count > 0)
                {
                    await client.PatchAsJsonAsync(
                        $"/{SharedConstants.Paths.Video}/{a.VideoId}/{SharedConstants.Paths.DetectedObjects}", bulkState);
                    if (_videoEditor is not null)
                        await _videoEditor.PushChangesToVue(new DetectedObjectChangeSet
                        {
                            ObjectsToUpdate = bulkState, ObjectsToRemove = [], ObjectsToAdd = []
                        });
                }
                break;
        }

        if (!isRedo)
        {
            _historyIndex--;
        }
    }

    private async Task OnStartAnonymizationClicked()
    {
        if (_videoEditor is null)
            return;

        _capturedFrames = (await _videoEditor.GetFramesAsync()).ToList();
        await StartAnonymization.InvokeAsync();
    }

    private async Task OnBlurSizeChanged(int value)
    {
        BlurSizePercent = value;
        await SaveSettingsAsync();
    }

    private async Task OnTimeBufferChanged(int value)
    {
        TimeBufferMs = value;
        await SaveSettingsAsync();
    }

    private async Task SaveSettingsAsync()
    {
        if (VideoId is null) return;

        if (_videoEditor is not null)
        {
            var item = AddAction("Save settings");
            _videoEditor.EnqueueOperation(async () =>
            {
                try
                {
                    using var client = HttpClientFactory.CreateClient("ApiService");
                    await client.PutAsJsonAsync(
                        $"/{SharedConstants.Paths.Video}/{VideoId}/{SharedConstants.Paths.VideoSettings}",
                        new AnonymizationSettingsDto { BlurSizePercent = BlurSizePercent, TimeBufferMs = TimeBufferMs });
                    item.Status = ActionStatus.Success;
                }
                catch
                {
                    MarkActionFailed(item);
                }
            });
        }
        else
        {
            var item = AddAction("Save settings");
            try
            {
                using var client = HttpClientFactory.CreateClient("ApiService");
                await client.PutAsJsonAsync(
                    $"/{SharedConstants.Paths.Video}/{VideoId}/{SharedConstants.Paths.VideoSettings}",
                    new AnonymizationSettingsDto { BlurSizePercent = BlurSizePercent, TimeBufferMs = TimeBufferMs });
                item.Status = ActionStatus.Success;
            }
            catch
            {
                MarkActionFailed(item);
            }
        }
    }
}
