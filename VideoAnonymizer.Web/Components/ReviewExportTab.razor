@using VideoAnonymizer.Web.Modules.Components
@using VideoAnonymizer.Web.Shared.DTO

<MudPaper Class="pa-6">
    <MudStack Spacing="2">
        <MudPaper Class="pa-3 mb-3">
            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                <MudStack Spacing="1" Style="width: 220px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.subtitle2">Blur size</MudText>
                        <MudTooltip Text="Controls how large the anonymized area is compared to the detected face box. Example: 120% means the blur area is 20% larger than the detected box.">
                            <MudIcon Icon="@Icons.Material.Filled.Info"
                                     Size="Size.Small"
                                     Color="Color.Info" />
                        </MudTooltip>
                    </MudStack>

                    <MudNumericField T="double"
                                     @bind-Value="_blurSizePercent"
                                     Min="100"
                                     Max="300"
                                     Step="10"
                                     Adornment="Adornment.End"
                                     AdornmentText="%"
                                     Immediate="false" />
                </MudStack>

                <MudStack Spacing="1" Style="width: 220px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.subtitle2">Time buffer</MudText>
                        <MudTooltip Text="Adds blur time before and after a detection, reducing flicker when detections appear or disappear. Example: 300 ms blurs 0.3 seconds before and after detection.">
                            <MudIcon Icon="@Icons.Material.Filled.Info"
                                     Size="Size.Small"
                                     Color="Color.Info" />
                        </MudTooltip>
                    </MudStack>

                    <MudNumericField T="int"
                                     @bind-Value="_timeBufferMs"
                                     Min="0"
                                     Max="1000"
                                     Step="50"
                                     Adornment="Adornment.End"
                                     AdornmentText="ms"
                                     Immediate="false" />
                </MudStack>
            </MudStack>

            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                These settings apply to the whole video, not to individual objects.
                The preview shows the affected area, not the final blur rendering.
            </MudAlert>
        </MudPaper>
        @if (ShowEditor && VideoId.HasValue && !string.IsNullOrWhiteSpace(VideoSourceUrl))
        {
            <VideoEditor VideoId="@VideoId.Value"
                         VideoSourceUrl="@VideoSourceUrl"
                         Frames="@Frames"
                         BlurSizePercent="@_blurSizePercent"
                         TimeBufferMs="@_timeBufferMs" />
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="!ShowEditor"
                   OnClick="OnStartAnonymizationClicked">
            Anonymize selected objects
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Secondary"
                   Disabled="@(!IsAnonymized || AnonymizeVideoJobId is null)"
                   OnClick="Download">
            Download
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private VideoEditor? _videoEditor;

    [Parameter]
    public Guid? VideoId { get; set; }

    [Parameter]
    public string? VideoSourceUrl { get; set; }

    [Parameter]
    public List<AnalyzedFrameDto> Frames { get; set; } = [];

    [Parameter]
    public bool ShowEditor { get; set; }

    [Parameter]
    public bool IsAnonymized { get; set; }

    [Parameter]
    public Guid? AnonymizeVideoJobId { get; set; }

    [Parameter, EditorRequired]
    public EventCallback StartAnonymization { get; set; }

    [Parameter, EditorRequired]
    public EventCallback Download { get; set; }

    private double _blurSizePercent = 150;
    private int _timeBufferMs = 300;

    private async Task OnStartAnonymizationClicked()
    {
        if (_videoEditor is null)
            return;

        Frames = (await _videoEditor.GetFramesAsync()).ToList();
        await StartAnonymization.InvokeAsync();
    }
}