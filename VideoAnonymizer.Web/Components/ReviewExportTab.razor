@using VideoAnonymizer.Web.Components.ReviewExport
@using VideoAnonymizer.Web.Modules.Actions
@using VideoAnonymizer.Web.Modules.Components
@using VideoAnonymizer.Web.Shared.DTO
@implements IAsyncDisposable
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar

<MudPaper Class="pa-6">
    <MudStack Spacing="2">
        <ReviewExportSettings BlurSizePercent="BlurSizePercent"
                              BlurSizePercentChanged="OnBlurSizeChanged"
                              TimeBufferMs="TimeBufferMs"
                              TimeBufferMsChanged="OnTimeBufferChanged">
            <ActionHistoryPopover IsProcessing="_videoEditorProcessing"
                                  HasErrors="_hasErrors"
                                  Items="_actionHistory" />
        </ReviewExportSettings>

        @if (ShowEditor && VideoId.HasValue && !string.IsNullOrWhiteSpace(VideoSourceUrl))
        {
            <div style="position: relative;">
                <VideoEditor @ref="_videoEditor"
                             VideoId="@VideoId.Value"
                             VideoSourceUrl="@VideoSourceUrl"
                             Frames="@Frames"
                             BlurSizePercent="@BlurSizePercent"
                             TimeBufferMs="@TimeBufferMs"
                             OnAction="OnVideoEditorAction" />

                @if (_editorInputBlocked)
                {
                    <div style="position: absolute; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.35);">
                        <MudPaper Class="pa-4 d-flex flex-column align-center" Style="gap: 12px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2">Finishing pending editor changes...</MudText>
                        </MudPaper>
                    </div>
                }
            </div>
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Secondary"
                   Disabled="!ShowEditor || _editorInputBlocked"
                   OnClick="OnStartAnonymizationClicked">
            Anonymize selected objects
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private readonly List<ActionHistoryItem> _actionHistory = [];
    private readonly VideoEditorActionQueue _actionQueue;
    private readonly VideoEditorUndoRedoState _undoRedoState = new();
    private VideoEditor? _videoEditor;
    private List<AnalyzedFrameDto> _capturedFrames = [];
    private bool _videoEditorProcessing;
    private bool _editorInputBlocked;
    private bool _hasErrors;

    public ReviewExportTab()
    {
        _actionQueue = new VideoEditorActionQueue(OnQueueProcessingChangedAsync);
    }

    [Parameter]
    public Guid? VideoId { get; set; }

    [Parameter]
    public string? VideoSourceUrl { get; set; }

    [Parameter]
    public List<AnalyzedFrameDto> Frames { get; set; } = [];

    [Parameter]
    public bool ShowEditor { get; set; }

    [Parameter, EditorRequired]
    public EventCallback StartAnonymization { get; set; }

    [Parameter]
    public int BlurSizePercent { get; set; } = 120;

    [Parameter]
    public EventCallback<int> BlurSizePercentChanged { get; set; }

    [Parameter]
    public int TimeBufferMs { get; set; } = 300;

    [Parameter]
    public EventCallback<int> TimeBufferMsChanged { get; set; }

    public IReadOnlyList<AnalyzedFrameDto> CapturedFrames => _capturedFrames;

    private Task OnQueueProcessingChangedAsync(bool isProcessing) =>
        InvokeAsync(() =>
        {
            _videoEditorProcessing = isProcessing;
            if (!isProcessing)
            {
                _editorInputBlocked = false;
            }

            StateHasChanged();
        });

    private Task OnVideoEditorAction(VideoEditorAction action)
    {
        if (_editorInputBlocked && action is UndoAction or RedoAction)
            return Task.CompletedTask;

        if (action is UndoAction or RedoAction && _actionQueue.HasPendingActions)
        {
            _editorInputBlocked = true;
            _ = InvokeAsync(StateHasChanged);
        }

        _actionQueue.Enqueue(() => ProcessVideoEditorActionAsync(action));
        return Task.CompletedTask;
    }

    private async Task ProcessVideoEditorActionAsync(VideoEditorAction action)
    {
        using var client = HttpClientFactory.CreateClient("ApiService");
        var persister = new VideoEditorActionPersister(client);

        switch (action)
        {
            case UndoAction:
                await ApplyUndoRedoAsync(persister, isRedo: false);
                break;

            case RedoAction:
                await ApplyUndoRedoAsync(persister, isRedo: true);
                break;

            default:
                await PersistActionAsync(persister, action);
                break;
        }
    }

    private async Task PersistActionAsync(VideoEditorActionPersister persister, VideoEditorAction action)
    {
        var item = AddAction(VideoEditorActionDescriptions.Get(action));

        try
        {
            await persister.SaveAsync(action);
            item.Status = ActionStatus.Success;
            _undoRedoState.Add(action, item);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            MarkActionFailed(item);
        }
    }

    private async Task ApplyUndoRedoAsync(VideoEditorActionPersister persister, bool isRedo)
    {
        var operation = _undoRedoState.Begin(isRedo);
        if (operation is null)
            return;

        try
        {
            await persister.ApplyUndoRedoAsync(operation.Action, isRedo, _videoEditor, ApplySettingsFromHistoryAsync);
            _undoRedoState.Complete(operation, isRedo);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            _undoRedoState.Rollback(isRedo);
            Snackbar.Add(isRedo ? "Failed to redo changes." : "Failed to undo changes.", Severity.Error);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ApplySettingsFromHistoryAsync(AnonymizationSettingsDto settings)
    {
        BlurSizePercent = settings.BlurSizePercent;
        TimeBufferMs = settings.TimeBufferMs;

        await BlurSizePercentChanged.InvokeAsync(settings.BlurSizePercent);
        await TimeBufferMsChanged.InvokeAsync(settings.TimeBufferMs);
        await InvokeAsync(StateHasChanged);
    }

    private ActionHistoryItem AddAction(string description)
    {
        var item = new ActionHistoryItem(description, DateTime.UtcNow);
        _actionHistory.Add(item);
        if (_actionHistory.Count > 20)
        {
            _actionHistory.RemoveAt(0);
        }

        return item;
    }

    private void MarkActionFailed(ActionHistoryItem item)
    {
        item.Status = ActionStatus.Failed;
        _hasErrors = true;
        _ = InvokeAsync(StateHasChanged);
        Snackbar.Add("Failed to save changes. Please refresh the page.", Severity.Error);
    }

    private async Task OnStartAnonymizationClicked()
    {
        if (_videoEditor is null)
            return;

        _capturedFrames = (await _videoEditor.GetFramesAsync()).ToList();
        await StartAnonymization.InvokeAsync();
    }

    private async Task OnBlurSizeChanged(int value)
    {
        var before = new AnonymizationSettingsDto { BlurSizePercent = BlurSizePercent, TimeBufferMs = TimeBufferMs };
        BlurSizePercent = value;
        await BlurSizePercentChanged.InvokeAsync(value);
        await SaveSettingsAsync(before);
    }

    private async Task OnTimeBufferChanged(int value)
    {
        var before = new AnonymizationSettingsDto { BlurSizePercent = BlurSizePercent, TimeBufferMs = TimeBufferMs };
        TimeBufferMs = value;
        await TimeBufferMsChanged.InvokeAsync(value);
        await SaveSettingsAsync(before);
    }

    private Task SaveSettingsAsync(AnonymizationSettingsDto? beforeState = null)
    {
        if (VideoId is null)
            return Task.CompletedTask;

        var afterState = new AnonymizationSettingsDto { BlurSizePercent = BlurSizePercent, TimeBufferMs = TimeBufferMs };
        var before = beforeState ?? afterState;

        return OnVideoEditorAction(new SettingsUpdatedAction
        {
            VideoId = VideoId.Value,
            BeforeState = before,
            AfterState = afterState
        });
    }

    public async ValueTask DisposeAsync()
    {
        await _actionQueue.DisposeAsync();
    }
}
