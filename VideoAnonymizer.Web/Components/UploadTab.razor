@using Microsoft.AspNetCore.Components.Forms
@using VideoAnonymizer.Web.Shared.DTO

<MudPaper Class="pa-6">
    <MudStack Spacing="4">

        <MudText Typo="Typo.h6">Import a new video</MudText>

        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudFileUpload T="IBrowserFile"
                           FilesChanged="OnFilesChanged"
                           Accept="video/*"
                           Hidden="true">
                <CustomContent>
                    <MudButton HtmlTag="label"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.VideoFile"
                               OnClick="@context.OpenFilePickerAsync"
                               Disabled="@IsBusy">
                        Select Video
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>

            <MudText Typo="Typo.body1">
                Choose a video file.
            </MudText>

            @if (!string.IsNullOrWhiteSpace(SelectedFileName))
            {
                <MudPaper Outlined="true" Class="pa-3">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
                        <MudText Typo="Typo.body1">@SelectedFileName</MudText>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
        <MudDivider />
        <MudStack Spacing="1">
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body1">Detection interval (ms)</MudText>

                <MudTooltip Text="Time between analyzed frames. A smaller detection interval improves object tracking, but increases processing time."
                            Placement="Placement.Right">
                    <MudIconButton Icon="@Icons.Material.Filled.HelpOutline"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   Disabled="@IsBusy" />
                </MudTooltip>
            </MudStack>
            <MudNumericField T="int"
                             Value="DetectionIntervalMs"
                             ValueChanged="OnDetectionIntervalChanged"
                             Variant="Variant.Outlined"
                             Min="50"
                             Max="5000"
                             Step="50"
                             Immediate="true"
                             HideSpinButtons="false"
                             Disabled="@IsBusy"
                             Style="width: 140px;" />
        </MudStack>
        <MudDivider />
        <MudStack AlignItems="AlignItems.Start">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Search"
                       Disabled="@(!CanDetect)"
                       OnClick="DetectObjectsClicked">
                Detect Objects
            </MudButton>
        </MudStack>

        @if (ExistingVideos?.Count > 0)
        {
            <MudDivider />
            <MudText Typo="Typo.h6">Imported Videos</MudText>

            <MudPaper Outlined="true" Class="pa-0">
                <MudTable Items="@ExistingVideos" Hover="true" Dense="true" Elevation="0">
                    <HeaderContent>
                        <MudTh><MudText Typo="Typo.body2">File Name</MudText></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="File Name">
                            <div @onclick="@(() => OnExistingVideoSelected.InvokeAsync(context.Id))"
                                 @onclick:preventDefault="false"
                                 Style="cursor: pointer; padding: 4px 0;"
                                 class="@(IsBusy ? "disabled" : "")">
                                <MudText Typo="Typo.body1">@context.OriginalFileName</MudText>
                            </div>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public EventCallback<IBrowserFile?> SelectedFileChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback DetectObjects { get; set; }

    [Parameter]
    public EventCallback<Guid> OnExistingVideoSelected { get; set; }

    [Parameter]
    public List<VideoDto>? ExistingVideos { get; set; }

    [Parameter]
    public string? SelectedFileName { get; set; }

    [Parameter]
    public int DetectionIntervalMs { get; set; } = 100;

    [Parameter]
    public EventCallback<int> DetectionIntervalMsChanged { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private bool CanDetect => !IsBusy && !string.IsNullOrWhiteSpace(SelectedFileName);

    private async Task OnFilesChanged(IBrowserFile? file)
    {
        await SelectedFileChanged.InvokeAsync(file);
    }

    private async Task OnDetectionIntervalChanged(int value)
    {
        DetectionIntervalMs = value;
        await DetectionIntervalMsChanged.InvokeAsync(value);
    }

    private async Task DetectObjectsClicked()
    {
        await DetectObjects.InvokeAsync();
    }
}