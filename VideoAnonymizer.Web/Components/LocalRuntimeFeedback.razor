@using VideoAnonymizer.Web.Shared.DTO

@if (AppState?.CudaRuntime is not null)
{
    var cuda = AppState.CudaRuntime;

    <div class="@Class" style="display: flex; justify-content: flex-end;">
        <MudTooltip Text="@GetTooltip(cuda, AppState.IsDocker)">
            <div style="@GetHeaderStyle(cuda)">
                <span style="@GetDotStyle(cuda)"></span>
                <span>@GetHeaderText(cuda)</span>
            </div>
        </MudTooltip>
    </div>
}

@code {
    [Parameter]
    public AppStateDto? AppState { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public LocalRuntimeFeedbackMode Mode { get; set; } = LocalRuntimeFeedbackMode.Header;

    private static string GetHeaderText(CudaRuntimeStateDto cuda)
    {
        return cuda.CudaExecutionProviderActive
            ? "GPU mode"
            : "CPU mode";
    }

    private static string GetTooltip(CudaRuntimeStateDto cuda, bool isDocker)
    {
        if (cuda.CudaExecutionProviderActive)
        {
            return $"GPU acceleration is active. Providers: {FormatProviders(cuda.ActiveProviders)}";
        }

        return isDocker
            ? "Consider passing a GPU when starting the image, for faster video processing."
            : "Install CUDA Toolkit 12.x and cuDNN 9.x for CUDA 12 for faster video processing.";
    }

    private static string GetHeaderStyle(CudaRuntimeStateDto cuda)
    {
        var color = cuda.CudaExecutionProviderActive
            ? "var(--mud-palette-success)"
            : "var(--mud-palette-warning)";

        return $"display: inline-flex; align-items: center; gap: 8px; min-height: 28px; padding: 3px 10px; border: 1px solid {color}; border-radius: 999px; color: {color}; font-size: 0.78rem; line-height: 1; background: rgba(255,255,255,0.02);";
    }

    private static string GetDotStyle(CudaRuntimeStateDto cuda)
    {
        var color = cuda.CudaExecutionProviderActive
            ? "var(--mud-palette-success)"
            : "var(--mud-palette-warning)";

        return $"display: inline-block; width: 7px; height: 7px; border-radius: 999px; background: {color}; box-shadow: 0 0 0 3px color-mix(in srgb, {color} 20%, transparent);";
    }

    private static string FormatProviders(string[] providers)
    {
        return providers.Length == 0
            ? "unknown"
            : string.Join(", ", providers);
    }

}
