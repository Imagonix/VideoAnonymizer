@using VideoAnonymizer.Web.Shared.DTO

@if (AppState is { IsStandalone: true, CudaRuntime: not null })
{
    var cuda = AppState.CudaRuntime;

    @if (Mode == LocalRuntimeFeedbackMode.Header)
    {
        <div class="@Class" style="display: flex; justify-content: flex-end;">
            <MudTooltip Text="@GetHeaderTooltip(cuda)">
                <div style="@GetHeaderStyle(cuda)">
                    <span style="@GetDotStyle(cuda)"></span>
                    <span>@GetHeaderText(cuda)</span>
                </div>
            </MudTooltip>
        </div>
    }
    else if (!cuda.CudaExecutionProviderActive)
    {
        @if (Mode == LocalRuntimeFeedbackMode.Center)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true" Class="@Class">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.subtitle2">@GetTitle(cuda)</MudText>
                    <MudText Typo="Typo.body2">@GetProblemSummary(cuda)</MudText>
                    <MudText Typo="Typo.caption">@GetSetupHint(cuda)</MudText>
                </MudStack>
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="@Class">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.subtitle2">@GetTitle(cuda)</MudText>
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">CPU</MudChip>
                    </MudStack>

                    <MudText Typo="Typo.body2">@GetProblemSummary(cuda)</MudText>
                    <MudText Typo="Typo.caption">@GetProviderText(cuda)</MudText>
                    <MudText Typo="Typo.caption">@GetSetupHint(cuda)</MudText>
                </MudStack>
            </MudAlert>
        }
    }
}

@code {
    [Parameter]
    public AppStateDto? AppState { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public LocalRuntimeFeedbackMode Mode { get; set; } = LocalRuntimeFeedbackMode.Banner;

    private static string GetTitle(CudaRuntimeStateDto cuda)
    {
        if (cuda.CudaExecutionProviderActive)
        {
            return "CUDA acceleration active";
        }

        if (cuda.NvidiaGpuDetected || cuda.CudaProviderAvailable)
        {
            return "CUDA not active";
        }

        return "CPU mode warning";
    }

    private static string GetHeaderText(CudaRuntimeStateDto cuda)
    {
        return cuda.CudaExecutionProviderActive
            ? "CUDA active"
            : "CPU mode";
    }

    private static string GetHeaderTooltip(CudaRuntimeStateDto cuda)
    {
        return cuda.CudaExecutionProviderActive
            ? $"GPU acceleration is active. Providers: {FormatProviders(cuda.ActiveProviders)}"
            : "Object detection is running on CPU. Analysis may be slow.";
    }

    private static string GetProblemSummary(CudaRuntimeStateDto cuda)
    {
        return string.IsNullOrWhiteSpace(cuda.Summary)
            ? "Object detection is running on CPU. Analysis may be slow."
            : cuda.Summary;
    }

    private static string GetProviderText(CudaRuntimeStateDto cuda)
    {
        var providers = FormatProviders(cuda.ActiveProviders);
        var missing = cuda.MissingDependencies.Length == 0
            ? string.Empty
            : $" Missing: {string.Join(", ", cuda.MissingDependencies)}.";
        var initializationError = string.IsNullOrWhiteSpace(cuda.InitializationError)
            ? string.Empty
            : $" CUDA error: {TrimError(cuda.InitializationError)}.";

        return $"Active provider: {providers}.{missing}{initializationError}";
    }

    private static string GetSetupHint(CudaRuntimeStateDto cuda)
    {
        if (!string.IsNullOrWhiteSpace(cuda.Recommendation))
        {
            return cuda.Recommendation;
        }

        return "Install CUDA Toolkit 12.x and cuDNN 9.x for CUDA 12, add the CUDA bin folder to PATH, then restart the app.";
    }

    private static string GetHeaderStyle(CudaRuntimeStateDto cuda)
    {
        var color = cuda.CudaExecutionProviderActive
            ? "var(--mud-palette-success)"
            : "var(--mud-palette-warning)";

        return $"display: inline-flex; align-items: center; gap: 8px; min-height: 28px; padding: 3px 10px; border: 1px solid {color}; border-radius: 999px; color: {color}; font-size: 0.78rem; line-height: 1; background: rgba(255,255,255,0.02);";
    }

    private static string GetDotStyle(CudaRuntimeStateDto cuda)
    {
        var color = cuda.CudaExecutionProviderActive
            ? "var(--mud-palette-success)"
            : "var(--mud-palette-warning)";

        return $"display: inline-block; width: 7px; height: 7px; border-radius: 999px; background: {color}; box-shadow: 0 0 0 3px color-mix(in srgb, {color} 20%, transparent);";
    }

    private static string FormatProviders(string[] providers)
    {
        return providers.Length == 0
            ? "unknown"
            : string.Join(", ", providers);
    }

    private static string TrimError(string error)
    {
        const int maxLength = 180;
        return error.Length <= maxLength
            ? error
            : $"{error[..maxLength]}...";
    }
}
