@page "/"
@using System.Net.Http.Json
@using VideoAnonymizer.Web.Shared
@using VideoAnonymizer.Web.Shared.DTO
@implements IDisposable

@inject IHttpClientFactory HttpClientFactory

@if (IsReady)
{
    <Home />
}
else
{
    <div style="height: 100vh; width: 100vw; display: flex; align-items: center; justify-content: center; background-color: #32333d;">
        <div style="text-align: center;">
            <svg width="90" height="90" viewBox="0 0 100 100" class="loading-spinner">
                <circle cx="50" cy="50" r="40" fill="none" stroke="#444" stroke-width="9" />
                <circle cx="50" cy="50" r="40" fill="none" stroke="#7b6cf6"
                        stroke-width="9" stroke-linecap="round" stroke-linejoin="round"
                        stroke-dasharray="251" stroke-dashoffset="251"
                        class="loading-progress-circle" />
            </svg>

            <div style="margin-top: 28px; font-size: 1.2rem; font-weight: 500; color: #ffffff;">
                @GetLoadingMessage()
            </div>
        </div>
    </div>
}

@code {
    private CancellationTokenSource? _cts;
    private AppStateDto _appState = new();
    private bool _pollingStarted;

    private bool IsReady =>
        _appState is
        {
            ObjectDetectionApiRunning: true,
            ModelAvailable: true
        };

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        await LoadStateAsync(_cts.Token);
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_pollingStarted && !IsReady && _cts is not null)
        {
            _pollingStarted = true;
            _ = PollAsync(_cts.Token);
        }

        return Task.CompletedTask;
    }

    private async Task PollAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(2000, cancellationToken);
                await LoadStateAsync(cancellationToken);

                if (IsReady)
                {
                    break;
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task LoadStateAsync(CancellationToken cancellationToken)
    {
        using var httpClient = HttpClientFactory.CreateClient("ApiService");

        try
        {
            _appState = await httpClient.GetFromJsonAsync<AppStateDto>(
                SharedConstants.Paths.AppState,
                cancellationToken) ?? new AppStateDto();
        }
        catch
        {
            _appState = new AppStateDto();
        }

        await InvokeAsync(StateHasChanged);
    }

    private string GetLoadingMessage()
    {
        if (_appState is not { ObjectDetectionApiRunning: true })
        {
            return "Starting AI Service ...";
        }

        return "Preparing Face Recognition Model ...";
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}