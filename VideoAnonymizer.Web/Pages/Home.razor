@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using VideoAnonymizer.Web.Components

@implements IAsyncDisposable
@inject IDownloadService DownloadService
@inject IHttpClientFactory HttpClientFactory
@inject IJobHubClient JobHubClient
@inject ISnackbar Snackbar
<MudOverlay Visible="@IsBusy" Class="d-flex align-center justify-center" DarkBackground="true" ZIndex="2000">
    <StatusIndicator StatusText="@StatusText" />
</MudOverlay>
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h4">Video Anonymizer</MudText>
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_activeTabIndex">
            <MudTabPanel Text="Upload" >
                <MudPaper Class="pa-6" >
                    <MudFileUpload T="IBrowserFile"
                                   FilesChanged="OnFileSelected"
                                   Accept="video/*"
                                   Hidden="true">
                        <CustomContent>
                            <MudButton HtmlTag="label"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.VideoFile"
                                       OnClick="@context.OpenFilePickerAsync"
                                       Class="upload-video-button">
                                Upload Video
                            </MudButton>
                        </CustomContent>
                        <SelectedTemplate />
                    </MudFileUpload>

                    @if (!string.IsNullOrWhiteSpace(SelectedFileName))
                    {
                        <MudText Typo="Typo.body2">Selected file: @SelectedFileName</MudText>
                    }
                </MudPaper>
            </MudTabPanel>
            <MudTabPanel Text="Review & Export">
                <MudPaper Class="pa-6">
                    <MudStack Spacing="2">
                        
                        @if (_showEditor && _currentVideoId.HasValue && !string.IsNullOrWhiteSpace(_videoSourceUrl))
                        {
                            <VideoEditor VideoId="@_currentVideoId.Value"
                                         VideoSourceUrl="@_videoSourceUrl"
                                         Frames="@_analyzedFrames"
                                         @ref=_videoEditor />
                        }
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="!_showEditor"
                                   OnClick="StartAnonymizationAsync">
                            Anonymize selected objects
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   Disabled="@(!IsAnonymized || _anonymizeVideoJobId.IsNullOrEmpty())"
                                   OnClick="DownloadAsync">
                            Download
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudTabPanel>
        </MudTabs>
    </MudStack>
</MudContainer>