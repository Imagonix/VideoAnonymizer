@using VideoAnonymizer.Web.Components

@implements IAsyncDisposable
@inject IDownloadService DownloadService
@inject IHttpClientFactory HttpClientFactory
@inject IJobHubClient JobHubClient
@inject ISnackbar Snackbar

<MudOverlay Visible="@IsBusy" Class="d-flex align-center justify-center" DarkBackground="true" ZIndex="2000">
    <StatusIndicator StatusText="@StatusText" ProgressPercent="@ProgressPercent" />
</MudOverlay>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap: 16px;">
            <MudText Typo="Typo.h4">Video Anonymizer</MudText>
            <LocalRuntimeFeedback AppState="InitialAppState" Mode="LocalRuntimeFeedbackMode.Header" />
        </MudStack>

        @if (_activeTabIndex == 0)
        {
            <LocalRuntimeFeedback AppState="InitialAppState" Mode="LocalRuntimeFeedbackMode.Banner" />
        }

        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_activeTabIndex">
            <MudTabPanel Text="Upload">
                <UploadTab SelectedFileChanged="OnFileSelected"
                           DetectObjects="DetectObjectsAsync"
                           SelectedFileName="@SelectedFileName"
                           @bind-DetectionIntervalMs="@DetectionIntervalMs"
                           IsBusy="@IsBusy" />
            </MudTabPanel>

            <MudTabPanel Text="Review & Export">
                <ReviewExportTab @ref="_reviewExportTab"
                                 VideoId="@_currentVideoId"
                                 VideoSourceUrl="@_videoSourceUrl"
                                 Frames="@_analyzedFrames"
                                 ShowEditor="@_showEditor"
                                 StartAnonymization="StartAnonymizationAsync"/>
            </MudTabPanel>
        </MudTabs>
    </MudStack>
</MudContainer>
