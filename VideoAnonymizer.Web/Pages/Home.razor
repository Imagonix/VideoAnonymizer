@page "/"

@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using VideoAnonymizer.Web.Contracts
@using VideoAnonymizer.Web.Services

@inject IHttpClientFactory HttpClientFactory 
@inject IJobHubClient JobHubClient
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudPaper Class="pa-6">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h4">Video Anonymizer</MudText>

            <MudFileUpload T="IBrowserFile"
                           FilesChanged="OnFileSelected"
                           Accept="video/*"
                           Hidden="false">
                <ButtonTemplate>
                    <MudButton HtmlTag="label"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.UploadFile">
                        Upload
                    </MudButton>
                </ButtonTemplate>
            </MudFileUpload>

            @if (!string.IsNullOrWhiteSpace(SelectedFileName))
            {
                <MudText Typo="Typo.body2">Selected file: @SelectedFileName</MudText>
            }

            @if (IsBusy)
            {
                <MudProgressLinear Indeterminate="true" />
                <MudText Typo="Typo.body2">@StatusText</MudText>
            }
            else if (!string.IsNullOrWhiteSpace(StatusText))
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    @StatusText
                </MudAlert>
            }

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Secondary"
                           Disabled="@(!IsAnonymized || string.IsNullOrWhiteSpace(_anonymizedVideoId))"
                           OnClick="DownloadAsync">
                    Download
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private IDisposable? _videoAnalyzedSubscription;
    private IDisposable? _videoAnonymizedSubscription;

    private IBrowserFile? _selectedFile;
    private string? _currentVideoId;
    private string? _anonymizedVideoId;

    public bool IsAnonymized { get; private set; }

    private bool IsBusy { get; set; }
    private string? StatusText { get; set; }
    private string? SelectedFileName { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _videoAnalyzedSubscription = JobHubClient.OnVideoAnalyzed(async message =>
        {
            if (string.IsNullOrWhiteSpace(_currentVideoId))
                return;

            if (!IsSameId(message.JobId, _currentVideoId))
                return;

            StatusText = "Video analyzed. Starting anonymization...";
            await InvokeAsync(StateHasChanged);

            await StartAnonymizationAsync(_currentVideoId);
        });

        _videoAnonymizedSubscription = JobHubClient.OnVideoAnonymized(async message =>
        {
            _anonymizedVideoId = message.JobId.ToString();
            IsAnonymized = true;
            IsBusy = false;
            StatusText = "Video anonymized successfully.";

            await InvokeAsync(StateHasChanged);
        });

        await JobHubClient.StartAsync();
    }

    private async Task OnFileSelected(IBrowserFile? file)
    {
        if (file is null)
            return;

        _selectedFile = file;
        SelectedFileName = file.Name;
        IsAnonymized = false;
        _currentVideoId = null;
        _anonymizedVideoId = null;
        IsBusy = true;
        StatusText = "Uploading and analyzing video...";

        await InvokeAsync(StateHasChanged);

        try
        {
            using var content = new MultipartFormDataContent();
            await using var stream = file.OpenReadStream(long.MaxValue);

            using var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "uploadedVideo", file.Name);

            using var httpClient = HttpClientFactory.CreateClient("ApiService");
            var response = await httpClient.PostAsync("/analyze", content);
            response.EnsureSuccessStatusCode();

            var result = await response.Content.ReadFromJsonAsync<AnalyzeResponse>();

            if (result is null || string.IsNullOrWhiteSpace(result.VideoId))
                throw new InvalidOperationException("Analyze endpoint did not return a video id.");

            _currentVideoId = result.VideoId;
            StatusText = "Video uploaded. Waiting for analysis result...";
        }
        catch (Exception ex)
        {
            IsBusy = false;
            StatusText = "Upload failed.";
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task StartAnonymizationAsync(string videoId)
    {
        try
        {
            using var httpClient = HttpClientFactory.CreateClient("ApiService");
            var response = await httpClient.PostAsync($"/anonymize/{videoId}", content: null);
            response.EnsureSuccessStatusCode();

            var result = await response.Content.ReadFromJsonAsync<AnalyzeResponse>();

            if (result is not null && !string.IsNullOrWhiteSpace(result.VideoId))
            {
                _anonymizedVideoId = result.VideoId;
            }

            StatusText = "Anonymization started. Waiting for completion...";
        }
        catch (Exception ex)
        {
            IsBusy = false;
            StatusText = "Anonymization failed.";
            Snackbar.Add($"Anonymization failed: {ex.Message}", Severity.Error);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task DownloadAsync()
    {
        if (string.IsNullOrWhiteSpace(_anonymizedVideoId))
            return;

        try
        {
            using var httpClient = HttpClientFactory.CreateClient("ApiService");
            using var response = await httpClient.GetAsync($"/anonymized/{_anonymizedVideoId}");
            response.EnsureSuccessStatusCode();

            StatusText = "Download started.";
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Download failed: {ex.Message}", Severity.Error);
        }

        await InvokeAsync(StateHasChanged);
    }

    private static bool IsSameId(Guid jobId, string expectedId)
        => Guid.TryParse(expectedId, out var parsed) && parsed == jobId;

    public async ValueTask DisposeAsync()
    {
        _videoAnalyzedSubscription?.Dispose();
        _videoAnonymizedSubscription?.Dispose();
        await JobHubClient.StopAsync();
    }

    private sealed class AnalyzeResponse
    {
        public string? VideoId { get; set; }
    }
}